.row-fluid,.row-fluid .span12{width:100%}#sheet,#sheet .overlay{bottom:0;left:0;right:0;top:0}.column,.row{display:flex}.cursor-pointer,button{cursor:pointer}:root{--background:#fff;--foreground:#000;--divider:#dcdcdc;--overlay:#888}@media (prefers-color-scheme:dark){:root{--background:#000;--foreground:#fff;--divider:#333}}.country-row{padding-top:20px}.row-fluid{background:#fff;position:relative;z-index:2;-webkit-transform:translate3d(0,0,0);transform:translate(0,0);-moz-box-sizing:border-box;box-sizing:border-box}.content-body,button{background:var(--background);color:var(--foreground)}.containerCentered{margin-right:auto;margin-left:auto;-moz-box-sizing:content-box;box-sizing:content-box;min-width:940px;max-width:1150px}.row-fluid [class*=span]:first-child{margin-left:0}.row-fluid [class*=span]{float:left;margin-left:2%;min-height:1px;-moz-box-sizing:border-box;box-sizing:border-box}.country-row .country-selector{float:none;text-align:left}.country-row ul{display:block}.country-selector{float:right;text-align:right;margin-top:8px}.content-body{overflow:hidden;line-height:1.5;-webkit-tap-highlight-color:transparent}button{padding:1rem;font-size:1rem;border-radius:1rem;border:.0625rem solid var(--divider)}#sheet{position:fixed;z-index:2;visibility:visible;transition:opacity .5s,visibility .5s}#sheet[aria-hidden=true]{opacity:0;visibility:hidden;pointer-events:none}#sheet .overlay{position:absolute;z-index:-1;background:var(--overlay);opacity:.5}#sheet .contents{border-radius:1rem 1rem 0 0;background:var(--background);position:relative;overflow-y:hidden;--default-transitions:transform 0.5s,border-radius 0.5s;transition:var(--default-transitions);transform:translateY(0);max-height:100vh;height:30vh;max-width:100rem;box-sizing:border-box;padding:3rem 1rem 1rem}#sheet .contents:not(.not-selectable){transition:var(--default-transitions),height .5s}#sheet .contents.fullscreen{border-radius:0}#sheet[aria-hidden=true] .contents{transform:translateY(100%)}#sheet .draggable-area{position:absolute;top:0;left:0;right:0;width:3rem;margin:auto;padding:1rem;cursor:grab}#sheet .draggable-thumb{width:inherit;height:.25rem;background:var(--divider);border-radius:.125rem}#sheet .close-sheet{position:absolute;right:0;top:0;border:none}#sheet .body{height:100%;overflow-y:auto;gap:1rem}.row{flex-direction:row}.row.reversed-order{flex-direction:row-reverse}.column{flex-direction:column}.column.reversed-order{flex-direction:column-reverse}.column.items-start,.row.items-start{align-items:flex-start}.column.justify-start,.row.justify-start{justify-content:flex-start}.column.content-start,.row.content-start{align-content:flex-start}.column.items-center,.row.items-center{align-items:center}.column.justify-center,.row.justify-center{justify-content:center}.column.content-center,.row.content-center{align-content:center}.column.items-end,.row.items-end{align-items:flex-end}.column.justify-end,.row.justify-end{justify-content:flex-end}.column.content-end,.row.content-end{align-content:flex-end}.column.items-stretch,.row.items-stretch{align-items:stretch}.column.justify-stretch,.row.justify-stretch{justify-content:stretch}.column.content-stretch,.row.content-stretch{align-content:stretch}.column.items-baseline,.row.items-baseline{align-items:baseline}.column.justify-baseline,.row.justify-baseline{justify-content:baseline}.column.content-baseline,.row.content-baseline{align-content:baseline}.column .wrap,.row .wrap{flex-wrap:wrap}.column .reversed-wrap,.row .reversed-wrap{flex-wrap:wrap-reverse}.column .no-wrap,.row .no-wrap{flex-wrap:nowrap}.fill{flex-grow:1;flex-shrink:0}.font-system{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Ubuntu,Helvetica,Arial,sans-serif,"Apple Color Emoji","Segoe UI Emoji","Segoe UI Symbol"}.font-thin{font-weight:100}.font-extra-light{font-weight:200}.font-light{font-weight:300}.font-regular{font-weight:400}.font-medium{font-weight:500}.font-semibold{font-weight:600}.font-bold{font-weight:700}.font-extra-bold{font-weight:800}.font-black{font-weight:900}.not-selectable{user-select:none}.selectable{user-select:auto}